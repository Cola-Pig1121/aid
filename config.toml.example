# AID 配置文件
# 复制此文件为 config.toml 并填入您的配置

[modelscope]
# ModelScope API Key
api_key = "your_modelscope_api_key_here"
# Base URL (可选)
# base_url = "https://api-inference.modelscope.cn/v1"
# 模型选择 (可选)
model = "Qwen/Qwen3.5-27B"

[openrouter]
# OpenRouter API Key
# api_key = "your_openrouter_api_key_here"
# Base URL (可选)
# base_url = "https://openrouter.ai/api/v1"
# 模型选择 (可选)
# model = "qwen/qwen-2.5-72b-instruct"

[llm]
# Temperature (可选，默认: 0.7)
temperature = 0.7

[server]
# 端口 (可选，默认: 7860)
port = 7860

[search]
# Tavily API Key (可选，用于搜索功能)
# api_key = "your_tavily_api_key_here"

[location]
# 腾讯地图 API Key
tencent_key = "your_tencent_map_key"
# 腾讯地图 Secret Key
tencent_sk = "your_tencent_map_sk"
