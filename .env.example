# 选择 API 提供商: openrouter 或 modelscope
# 如果设置了 MODELSCOPE_API_KEY，则自动使用 ModelScope
# 否则使用 OpenRouter

# ========== ModelScope 配置 (推荐) ==========
# ModelScope API Key
# 获取地址: https://www.modelscope.cn/my/myaccesstoken
MODELSCOPE_API_KEY=your_modelscope_api_key_here

# ModelScope Base URL (可选，默认: https://api-inference.modelscope.cn/v1)
# MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# ModelScope 模型选择 (可选，默认: Qwen/Qwen3.5-27B)
MODELSCOPE_MODEL=Qwen/Qwen3.5-27B

# ========== OpenRouter 配置 ==========
# OpenRouter API Key (如果不用 ModelScope，则使用这个)
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter 模型选择 (可选)
# OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# ========== 通用配置 ==========
# Temperature (可选，默认: 0.7)
LLM_TEMPERATURE=0.7

# Gradio 服务器端口 (可选，默认: 7860)
GRADIO_SERVER_PORT=7860

# ========== Tavily 搜索配置 (可选) ==========
# Tavily API Key (用于搜索功能)
# 获取地址: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

TENCENT_MAP_KEY=你的Key
TENCENT_MAP_SK=你的SK